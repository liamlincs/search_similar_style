{
  "ocr": {
    "backend": "rapidocr"
  },
  "auth": {
    "enabled": true,
    "image_url_secret": "replace-with-image-url-secret",
    "image_url_ttl_sec": 600,
    "api_keys": [
      {
        "user": "demo_user_a",
        "key": "replace-with-real-key-a"
      },
      {
        "user": "demo_user_b",
        "key": "replace-with-real-key-b"
      }
    ]
  },
  "catalog": {
    "db_path": "data/product_catalog.db",
    "import_source_dir": "",
    "public_endpoints": true,
    "web_auth": {
      "enabled": true,
      "captcha_enabled": true,
      "captcha_timezone": "Asia/Shanghai",
      "users": [
        {
          "username": "admin",
          "password": "change-me"
        },
        {
          "username": "merch",
          "password": "change-me-too"
        }
      ],
      "session_secret": "replace-with-catalog-session-secret",
      "session_ttl_sec": 43200,
      "cookie_name": "catalog_session"
    }
  },
  "debug": {
    "save_query_images": true,
    "query_image_dir": "outputs/debug_queries"
  },
  "paths": {
    "standard_dir": "data/standard_samples",
    "standard_pattern": "*",
    "image_exts": ["png", "jpg", "jpeg"],
    "test_dir": "data/test_samples"
  },
  "search": {
    "top_k": 5,
    "candidate_multiplier": 12,
    "recall_topn_cap": 768,
    "min_score": 0.64,
    "code_agg_top_n": 3,
    "code_agg_alpha": 0.70,
    "query_multicrop": true,
    "query_crop_ratio": 0.72,
    "query_component_views": true,
    "query_view_consensus_weight": 0.20,
    "standard_multicrop": false,
    "standard_crop_ratio": 0.72,
    "ocr_hint_enabled": false,
    "ocr_hint_boost": 0.08,
    "rerank_enabled": true,
    "reranker_model": "models/reranker_v1.npz",
    "rerank_topn": 36,
    "rerank_weight": 0.45,
    "rerank_query_views_max": 2,
    "rerank_candidate_views_max": 1,
    "rerank_max_unique_codes": 24,
    "preload_rerank_candidate_cache": false,
    "label_memory_enabled": true,
    "label_memory_path": "data/query_labels.json",
    "label_memory_sim_threshold": 0.90,
    "label_memory_max_boost": 0.09,
    "feature_cache_enabled": true,
    "db_feature_dtype": "float16",
    "result_image_max_edge": 768,
    "result_image_quality": 82,
    "feature_backend": "hybrid",
    "hybrid_weights": {
      "clip": 0.55,
      "shape": 0.30,
      "color": 0.15,
      "stripe": 0.10
    }
  }
}
