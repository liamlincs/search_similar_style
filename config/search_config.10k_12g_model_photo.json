{
  "ocr": {
    "backend": "rapidocr"
  },
  "auth": {
    "enabled": true,
    "image_url_secret": "replace-with-image-url-secret",
    "image_url_ttl_sec": 600,
    "api_keys": [
      {
        "user": "demo_user_a",
        "key": "replace-with-real-key-a"
      },
      {
        "user": "demo_user_b",
        "key": "replace-with-real-key-b"
      }
    ]
  },
  "catalog": {
    "db_path": "data/product_catalog.db",
    "import_source_dir": "",
    "public_endpoints": true,
    "web_auth": {
      "enabled": true,
      "captcha_enabled": true,
      "captcha_timezone": "Asia/Shanghai",
      "users": [
        {
          "username": "admin",
          "password": "change-me"
        },
        {
          "username": "merch",
          "password": "change-me-too"
        }
      ],
      "session_secret": "replace-with-catalog-session-secret",
      "session_ttl_sec": 43200,
      "cookie_name": "catalog_session"
    }
  },
  "debug": {
    "save_query_images": true,
    "query_image_dir": "outputs/debug_queries"
  },
  "paths": {
    "standard_dir": "data/standard_samples",
    "standard_pattern": "*",
    "image_exts": [
      "png",
      "jpg",
      "jpeg"
    ],
    "test_dir": "data/test_samples"
  },
  "search": {
    "top_k": 6,
    "candidate_multiplier": 16,
    "recall_topn_cap": 1200,
    "min_score": 0.64,
    "code_agg_top_n": 2,
    "code_agg_alpha": 0.75,
    "query_multicrop": true,
    "query_crop_ratio": 0.72,
    "query_component_views": true,
    "query_view_consensus_weight": 0.2,
    "query_max_edge": 960,
    "standard_multicrop": false,
    "standard_crop_ratio": 0.72,
    "ocr_hint_enabled": false,
    "ocr_hint_boost": 0.08,
    "rerank_enabled": false,
    "reranker_model": "models/reranker_v1.npz",
    "rerank_topn": 20,
    "rerank_weight": 0.4,
    "rerank_query_views_max": 1,
    "rerank_candidate_views_max": 1,
    "rerank_max_unique_codes": 12,
    "adaptive_second_pass_enabled": false,
    "adaptive_trigger_top1_below": 0.72,
    "adaptive_trigger_margin_below": 0.02,
    "adaptive_recall_topn_cap": 1400,
    "adaptive_candidate_multiplier": 18,
    "adaptive_query_component_views": true,
    "adaptive_query_view_consensus_weight": 0.45,
    "adaptive_rerank_topn": 40,
    "adaptive_rerank_query_views_max": 2,
    "adaptive_rerank_max_unique_codes": 24,
    "shape_consistency_enabled": true,
    "shape_consistency_aspect_weight": 0.08,
    "shape_consistency_fill_weight": 0.02,
    "shape_consistency_apply_topn": 160,
    "mask_consistency_enabled": true,
    "mask_consistency_weight": 0.05,
    "mask_consistency_apply_topn": 160,
    "stripe_consistency_enabled": true,
    "stripe_consistency_weight": 0.03,
    "stripe_consistency_apply_topn": 160,
    "pattern_consistency_enabled": true,
    "pattern_consistency_weight": 0.22,
    "pattern_consistency_apply_topn": 160,
    "pattern_code_boost_enabled": true,
    "pattern_code_boost_weight": 0.13,
    "pattern_code_boost_topn": 24,
    "checker_consistency_enabled": true,
    "checker_query_threshold": 0.08,
    "checker_boost_weight": 0.18,
    "checker_stripe_penalty_weight": 0.12,
    "checker_apply_topn": 160,
    "checker_code_boost_weight": 0.08,
    "checker_code_boost_topn": 24,
    "accent_pattern_enabled": true,
    "accent_pattern_seed_score_base": 1.08,
    "accent_pattern_boost_scale": 0.36,
    "accent_pattern_min_score": 0.42,
    "accent_pattern_max_injected": 24,
    "accent_pattern_min_pixels": 80,
    "accent_pattern_max_edge": 192,
    "accent_pattern_crop_enabled": true,
    "sleeve_pattern_enabled": true,
    "sleeve_pattern_seed_score_base": 0.98,
    "sleeve_pattern_boost_scale": 0.38,
    "sleeve_pattern_min_score": 0.3,
    "sleeve_pattern_max_injected": 40,
    "sleeve_pair_prior_boost": 0.18,
    "sleeve_pattern_skip_when_full_accent": true,
    "accessory_pattern_enabled": true,
    "accessory_pattern_seed_score_base": 0.92,
    "accessory_pattern_boost_scale": 0.24,
    "accessory_pattern_min_score": 0.5,
    "accessory_pattern_max_injected": 16,
    "accessory_hat_prior_boost": 0.1,
    "accessory_hat_code_prefixes": [
      "BM"
    ],
    "accessory_hat_code_boost": 0.16,
    "checker_suppress_when_accent": true,
    "checker_accent_suppress_below": 0.14,
    "phash_enabled": true,
    "phash_boost_weight": 0.06,
    "phash_apply_topn": 160,
    "scene_text_hint_enabled": true,
    "scene_text_min_token_len": 4,
    "scene_text_seed_score_base": 0.9,
    "scene_text_boost_scale": 0.2,
    "scene_text_max_candidates_per_token": 96,
    "scene_text_max_injected": 24,
    "low_confidence_enabled": true,
    "low_confidence_margin_threshold": 0.06,
    "low_confidence_top1_threshold": 0.78,
    "similar_images_topn": 6,
    "region_similar_images_topn": 6,
    "confidence_high_threshold": 0.1,
    "confidence_medium_threshold": 0.03,
    "display_score_scale": 6.0,
    "display_score_bias": 0.78,
    "strip_mode_enabled": true,
    "strip_aspect_threshold": 2.2,
    "strip_fill_threshold": 0.44,
    "strip_w_clip": 0.3,
    "strip_w_shape": 0.3,
    "strip_w_color": 0.1,
    "strip_w_stripe": 0.3,
    "preload_rerank_candidate_cache": false,
    "label_memory_enabled": true,
    "label_memory_path": "data/query_labels.json",
    "label_memory_sim_threshold": 0.9,
    "label_memory_max_boost": 0.09,
    "feature_cache_enabled": true,
    "db_feature_dtype": "float16",
    "result_image_max_edge": 640,
    "result_image_quality": 80,
    "region_crop_recall_enabled": true,
    "region_crop_recall_backend": "hybrid",
    "region_crop_recall_weight": 1.12,
    "region_crop_recall_topn_cap": 1200,
    "region_crop_suppress_accessory_enabled": true,
    "region_crop_suppress_accessory_min_score": 0.68,
    "region_crop_suppress_accessory_topn": 10,
    "region_crop_suppress_accessory_min_hits": 3,
    "region_standard_crop_ratio": 0.55,
    "region_hybrid_weights": {
      "clip": 0.45,
      "shape": 0.25,
      "color": 0.15,
      "stripe": 0.15
    },
    "feature_backend": "clip",
    "secondary_feature_backend": "hybrid",
    "secondary_recall_weight": 0.94,
    "hybrid_weights": {
      "clip": 0.8,
      "shape": 0.1,
      "color": 0.05,
      "stripe": 0.05
    },
    "secondary_hybrid_weights": {
      "clip": 0.5,
      "shape": 0.3,
      "color": 0.1,
      "stripe": 0.1
    }
  }
}
