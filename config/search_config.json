{
  "ocr": {
    "backend": "rapidocr"
  },
  "auth": {
    "enabled": true,
    "image_url_secret": "replace-with-image-url-secret",
    "image_url_ttl_sec": 600,
    "api_keys": [
      {
        "user": "demo_user_a",
        "key": "replace-with-real-key-a"
      },
      {
        "user": "demo_user_b",
        "key": "replace-with-real-key-b"
      }
    ]
  },
  "content_security": {
    "wechat": {
      "enabled": false,
      "appid": "",
      "appsecret": "",
      "fail_open": false,
      "timeout_sec": 10
    }
  },
  "catalog": {
    "db_path": "data/product_catalog.db",
    "import_source_dir": "",
    "public_endpoints": true,
    "image_max_edge": 420,
    "image_quality": 68,
    "web_auth": {
      "enabled": true,
      "captcha_enabled": true,
      "captcha_timezone": "Asia/Shanghai",
      "users": [
        {
          "username": "admin",
          "password": "change-me"
        },
        {
          "username": "merch",
          "password": "change-me-too"
        }
      ],
      "session_secret": "replace-with-catalog-session-secret",
      "session_ttl_sec": 43200,
      "cookie_name": "catalog_session"
    }
  },
  "debug": {
    "save_query_images": true,
    "query_image_dir": "outputs/debug_queries"
  },
  "ai_generation": {
    "seed": 2180967052,
    "model": "doubao-seedream-5-0-260128",
    "size": "2K",
    "output_format": "png",
    "sequential_image_generation": "disabled",
    "watermark": false
  },
  "paths": {
    "standard_dir": "data/standard_samples",
    "standard_pattern": "*",
    "image_exts": [
      "png",
      "jpg",
      "jpeg"
    ],
    "test_dir": "data/test_samples"
  },
  "search": {
    "top_k": 9,
    "candidate_multiplier": 10,
    "min_score": 0.64,
    "code_agg_top_n": 3,
    "code_agg_alpha": 0.7,
    "query_multicrop": true,
    "query_crop_ratio": 0.72,
    "query_component_views": false,
    "standard_multicrop": false,
    "standard_crop_ratio": 0.72,
    "region_crop_auto_expand_enabled": true,
    "region_crop_auto_expand_min_w": 0.38,
    "region_crop_auto_expand_min_h": 0.38,
    "region_crop_auto_expand_min_area": 0.14,
    "region_crop_context_pad_ratio": 0.35,
    "region_crop_context_min_area": 0.2,
    "region_crop_strict_small_enabled": true,
    "region_crop_strict_small_max_orig_area": 0.1,
    "region_crop_strict_small_min_expand_ratio": 1.6,
    "region_crop_wide_strip_aspect_threshold": 1.8,
    "region_crop_wide_strip_max_h": 0.42,
    "region_crop_disable_accent_when_strip": true,
    "region_strip_query_multicrop_enabled": true,
    "region_strip_query_crop_ratio": 0.62,
    "region_strip_query_component_views": false,
    "region_strip_query_view_consensus_weight": 0.0,
    "strict_small_query_weights": {
      "clip": 0.52,
      "shape": 0.3,
      "color": 0.06,
      "stripe": 0.12
    },
    "strict_small_region_code_prior_min_score": 0.62,
    "strict_small_region_result_rescue_min_score": 0.6,
    "strict_small_region_force_top_min_score": 0.62,
    "strict_small_region_recall_topn_cap": 240,
    "strict_small_region_query_multicrop_enabled": true,
    "strict_small_region_query_crop_ratio": 0.72,
    "strict_small_region_query_component_views": true,
    "strict_small_disable_consistency": true,
    "ocr_hint_enabled": false,
    "ocr_hint_boost": 0.08,
    "rerank_enabled": true,
    "reranker_model": "models/reranker_v1.npz",
    "rerank_topn": 12,
    "rerank_weight": 0.45,
    "rerank_query_views_max": 2,
    "rerank_candidate_views_max": 1,
    "label_memory_enabled": true,
    "label_memory_path": "data/query_labels.json",
    "label_memory_sim_threshold": 0.9,
    "label_memory_max_boost": 0.09,
    "feature_cache_enabled": true,
    "feature_backend": "hybrid",
    "hybrid_weights": {
      "clip": 0.55,
      "shape": 0.3,
      "color": 0.15,
      "stripe": 0.1
    },
    "similar_images_topn": 9
  }
}
