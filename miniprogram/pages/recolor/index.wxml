<view class="container">
  <view class="hero">
    <view class="title">局部改色</view>
    <view class="subtitle">选择图片，指定矩形区域与目标色，快速预览</view>
  </view>

  <view class="card">
    <button class="pick" bindtap="chooseImage">选择图片</button>
    <view wx:if="{{localImage}}" class="stage" bindtouchstart="handleStageTouchStart" bindtouchmove="handleStageTouchMove" bindtouchend="handleStageTouchEnd">
      <image class="stage-img" src="{{localImage}}" mode="aspectFit" />
      <view
        wx:if="{{selRect}}"
        class="sel-rect"
        style="left: {{selRect.x}}px; top: {{selRect.y}}px; width: {{selRect.w}}px; height: {{selRect.h}}px;"
      >
        <view class="sel-label">{{selRect.w}} x {{selRect.h}}</view>
      </view>
    </view>
    <view wx:if="{{localImage}}" class="hint">在图片上拖动可创建选区，拖动已选区域可移动</view>

    <view class="field">
      <text>目标色（调色板）</text>
      <view class="palette">
        <view
          wx:for="{{palette}}"
          wx:key="hex"
          class="swatch {{selectedColorIndex === index ? 'active' : ''}}"
          style="background: #{{item.hex}};"
          data-index="{{index}}"
          bindtap="selectColor"
        ></view>
      </view>
      <view class="picked">当前：{{palette[selectedColorIndex].name}} #{{palette[selectedColorIndex].hex}}</view>
    </view>

    <button class="clear" bindtap="clearSelection">清除选区</button>
    <view class="field"><text>强度：{{strength}}%</text><slider min="0" max="100" value="{{strength}}" bindchange="onStrengthChange" /></view>
    <view class="field"><text>羽化：{{feather}}%</text><slider min="0" max="10" value="{{feather}}" bindchange="onFeatherChange" /></view>

    <button class="run" loading="{{processing}}" bindtap="runRecolor">开始改色</button>
  </view>

  <view class="card" wx:if="{{recoloredUrl}}">
    <view class="subtitle2">改色结果（点击放大）</view>
    <image class="result-img" src="{{recoloredLocalUrl || recoloredUrl}}" mode="aspectFit" bindtap="previewResult" binderror="onResultImageError" />
    <view class="url-tip">结果地址：{{recoloredUrl}}</view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goSearchPage">搜款</view>
    <view class="nav-item" bindtap="goPrintPage">拼图打印</view>
    <view class="nav-item active" bindtap="goRecolorPage">局部改色</view>
  </view>
</view>
