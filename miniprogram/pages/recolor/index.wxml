<view class="container">
  <view class="hero">
    <view class="title">{{enterpriseAiEnabled ? '换色与搭配预览' : '抠图换色'}}</view>
    <view class="subtitle">{{enterpriseAiEnabled ? '抠图换色支持自动抠主体和局部融合预览' : '自动识别主体区域，快速调整衣服颜色'}}</view>
  </view>

  <view class="card">
    <button class="btn btn-primary" bindtap="chooseImage">选择主图</button>
    <view
      wx:if="{{localImage}}"
      class="stage"
      bindtouchstart="handleStageTouchStart"
      bindtouchmove="handleStageTouchMove"
      bindtouchend="handleStageTouchEnd"
    >
      <image class="stage-img" src="{{localImage}}" mode="aspectFit" />
      <view
        wx:if="{{enterpriseAiEnabled && mode === 'ai' && selRect}}"
        class="sel-rect"
        style="left: {{selRect.x}}px; top: {{selRect.y}}px; width: {{selRect.w}}px; height: {{selRect.h}}px;"
      >
        <view class="sel-label">目标</view>
      </view>
    </view>
    <view wx:if="{{enterpriseAiEnabled && mode === 'ai' && localImage}}" class="hint">在主图上框选要融合的位置</view>
  </view>

  <view class="card">
    <view wx:if="{{enterpriseAiEnabled}}" class="mode-switch">
      <view class="mode-item {{mode === 'fast' ? 'active' : ''}}" data-mode="fast" bindtap="switchMode">抠图换色</view>
      <view class="mode-item {{mode === 'ai' ? 'active' : ''}}" data-mode="ai" bindtap="switchMode">融合预览</view>
    </view>

    <view class="field">
      <view class="field-title">{{enterpriseAiEnabled && mode === 'ai' ? '预览目标色' : '目标色'}}</view>
      <view class="wheel-wrap">
        <view class="wheel-touch" bindtouchstart="onWheelTouchStart" bindtouchmove="onWheelTouchMove">
          <view class="color-wheel"></view>
          <view class="wheel-fade"></view>
        </view>
        <view class="picker-dot" style="left: {{pickX}}px; top: {{pickY}}px;"></view>
      </view>
      <view class="field-title sm">明度</view>
      <slider min="0" max="100" value="{{hsvV * 100}}" bindchange="onValueChange" />
      <view class="picked-row">
        <view class="color-chip" style="background-color: {{targetColor}};"></view>
        <view class="picked">当前颜色：#{{targetHex}}</view>
        <view wx:if="{{!enterpriseAiEnabled || mode === 'fast'}}" class="inline-action" bindtap="toggleFastParams">
          高级参数 {{fastParamsOpen ? '⌃' : '›'}}
        </view>
      </view>
    </view>

    <view wx:if="{{!enterpriseAiEnabled || mode === 'fast'}}">
      <view wx:if="{{fastParamsOpen}}" class="field"><text>强度：{{strength}}%</text><slider min="0" max="100" value="{{strength}}" bindchange="onStrengthChange" /></view>
      <view wx:if="{{fastParamsOpen}}" class="field"><text>羽化：{{feather}}%</text><slider min="0" max="10" value="{{feather}}" bindchange="onFeatherChange" /></view>
      <button class="btn btn-primary run" loading="{{processing}}" disabled="{{processingAi}}" bindtap="runRecolor">开始抠图换色</button>
    </view>

    <view wx:if="{{enterpriseAiEnabled && mode === 'ai'}}">
      <button class="btn btn-ghost" bindtap="chooseReferenceImage" data-slot="2">{{referenceImage2 ? '重新选择部件图' : '选择部件图'}}</button>
      <view
        wx:if="{{referenceImage2}}"
        class="stage ref-stage"
        bindtouchstart="handleRefTouchStart"
        bindtouchmove="handleRefTouchMove"
        bindtouchend="handleRefTouchEnd"
      >
        <image class="stage-img" src="{{referenceImage2}}" mode="aspectFit" />
        <view
          wx:if="{{componentRect}}"
          class="sel-rect ref-sel"
          style="left: {{componentRect.x}}px; top: {{componentRect.y}}px; width: {{componentRect.w}}px; height: {{componentRect.h}}px;"
        >
          <view class="sel-label">衣领</view>
        </view>
      </view>
      <view wx:if="{{referenceImage2}}" class="hint">框选衣领和中间装饰，尽量少框衣服背景</view>
      <view class="field-title">融合说明</view>
      <textarea
        class="prompt-input"
        maxlength="500"
        value="{{aiPrompt}}"
        placeholder="{{aiPromptPlaceholder}}"
        bindinput="onAiPromptInput"
      />
      <button class="btn btn-primary run" loading="{{processingAi}}" disabled="{{processing}}" bindtap="runAiRecolor">开始预览</button>
    </view>
  </view>

  <view class="card" wx:if="{{recoloredUrl}}">
    <view class="subtitle2">结果图（点击放大）</view>
    <image class="result-img" src="{{recoloredLocalUrl || recoloredUrl}}" mode="aspectFit" bindtap="previewResult" binderror="onResultImageError" />
    <view wx:if="{{(!enterpriseAiEnabled || mode === 'fast') && recolorMaskBackend}}" class="mode-tip">
      抠图后端：{{recolorMaskBackend}}（{{recolorMaskMode || 'auto'}}）
    </view>
    <view class="url-tip">结果地址：{{recoloredUrl}}</view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goSearchPage">以图搜款</view>
    <view class="nav-item active" bindtap="goRecolorPage">{{enterpriseAiEnabled ? '融合预览' : '抠图换色'}}</view>
    <view class="nav-item" bindtap="goPrintPage">拼图打印</view>
  </view>
</view>
