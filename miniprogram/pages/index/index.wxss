.container {
  padding: 28rpx;
  padding-bottom: 150rpx;
}

.hero {
  margin-bottom: 24rpx;
}

.mode-switch {
  margin-bottom: 18rpx;
  display: flex;
  justify-content: center;
}

.mode-switch-inner {
  background: #f1f2f6;
  border-radius: 999rpx;
  padding: 5rpx;
  display: flex;
  gap: 4rpx;
  width: 100%;
  max-width: 460rpx;
  box-sizing: border-box;
  box-shadow: inset 0 1rpx 2rpx rgba(15, 23, 42, 0.05);
}

.mode-item {
  flex: 1;
  text-align: center;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  color: #6b7280;
  font-weight: 500;
  transition: all 0.18s ease;
}

.mode-item.active {
  background: #ffffff;
  color: #111827;
  font-weight: 600;
  box-shadow:
    0 1rpx 2rpx rgba(15, 23, 42, 0.08),
    0 4rpx 10rpx rgba(15, 23, 42, 0.05);
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 2rpx;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #475569;
}

.panel {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 22rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 20rpx;
}

.catalog-panel {
  margin-bottom: 24rpx;
}

.catalog-input {
  width: 100%;
  height: 84rpx;
  box-sizing: border-box;
  border: 2rpx solid #dbe2ea;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #0f172a;
  background: #ffffff;
}

.tag-filter-list {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-filter-item {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #3730a3;
  font-size: 24rpx;
}

.tag-filter-item.active {
  background: #3730a3;
  color: #ffffff;
}

.catalog-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
}

.catalog-btn {
  height: 76rpx;
  line-height: 76rpx;
  font-size: 26rpx;
}

.catalog-result-wrap {
  margin-top: 18rpx;
}

.empty-card {
  margin-top: 18rpx;
  border-radius: 16rpx;
  padding: 20rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 24rpx;
  text-align: center;
}

.catalog-meta {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #64748b;
}

.catalog-end {
  margin-top: 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
}

.query-wrap {
  width: 100%;
  height: 420rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  background: #0f172a;
  touch-action: none;
}

.query-image {
  width: 100%;
  height: 100%;
}

.region-active {
  box-shadow: 0 0 0 4rpx rgba(29, 78, 216, 0.28);
}

.region-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.20);
  pointer-events: none;
}

.region-rect {
  position: absolute;
  box-sizing: border-box;
  border: 4rpx solid #22c55e;
  background: rgba(34, 197, 94, 0.12);
  box-shadow: 0 0 0 9999rpx rgba(15, 23, 42, 0.26);
  pointer-events: none;
}

.placeholder {
  height: 420rpx;
  border-radius: 20rpx;
  background: linear-gradient(140deg, #f1f5f9 0%, #e2e8f0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  background: #0ea5e9;
  color: #fff;
  font-weight: 700;
  line-height: 108rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.placeholder-text {
  color: #64748b;
  font-size: 25rpx;
}

.actions {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.region-actions {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

.region-btn {
  flex: 1 1 0;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 14rpx;
  border: none;
  background: #eef2ff;
  color: #3730a3;
  font-size: 25rpx;
  padding: 0 12rpx;
}

.region-btn.primary {
  background: #0f172a;
  color: #ffffff;
}

.search-tip {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
}

.btn {
  flex: 1 1 0;
  min-width: 0;
  border-radius: 14rpx;
  font-size: 28rpx;
  height: 84rpx;
  line-height: 84rpx;
  border: none;
  width: 100%;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 20rpx;
}

.actions button::after,
.region-actions button::after,
.retry-btn::after {
  border: none;
}

.btn-main {
  background: linear-gradient(135deg, #1d4ed8 0%, #1e40af 100%);
  color: #fff;
}

.btn-sub {
  background: #e0f2fe;
  color: #075985;
}

.loading-card,
.error-card {
  margin-top: 22rpx;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  font-size: 25rpx;
}

.loading-card {
  background: #e0f2fe;
  color: #0369a1;
}

.error-card {
  background: #fef2f2;
  color: #b91c1c;
}

.retry-wrap {
  margin-top: 12rpx;
}

.retry-btn {
  width: 100%;
  height: 82rpx;
  line-height: normal;
  border-radius: 14rpx;
  border: none;
  background: #0f172a;
  color: #ffffff;
  font-size: 27rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-section {
  margin-top: 26rpx;
}

.section-title {
  font-size: 31rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
  color: #0f172a;
}

.ambiguous-tip,
.medium-tip {
  border-radius: 12rpx;
  padding: 12rpx 14rpx;
  margin-bottom: 12rpx;
  font-size: 23rpx;
}

.ambiguous-tip {
  background: #fff7ed;
  color: #c2410c;
}

.medium-tip {
  background: #eff6ff;
  color: #1d4ed8;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.result-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.card-image {
  width: 100%;
  height: 360rpx;
}

.result-card {
  border-radius: 14rpx;
}

.result-image {
  height: 170rpx;
  background: #f1f5f9;
}

.card-body {
  padding: 16rpx 18rpx 20rpx;
}

.result-body {
  padding: 9rpx 10rpx 11rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rank {
  background: #0f172a;
  color: #fff;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
  font-size: 22rpx;
}

.result-card .rank {
  padding: 2rpx 8rpx;
  font-size: 17rpx;
}

.score {
  color: #16a34a;
  font-size: 24rpx;
  font-weight: 600;
}

.result-card .score {
  font-size: 18rpx;
}

.style-code {
  margin-top: 10rpx;
  font-size: 34rpx;
  letter-spacing: 1rpx;
  color: #0f172a;
  font-weight: 700;
}

.result-style-code {
  margin-top: 7rpx;
  font-size: 22rpx;
  line-height: 1.15;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.result-tags {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.result-grid-tags {
  margin-top: 6rpx;
  gap: 4rpx;
  min-height: 24rpx;
}

.result-tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #3730a3;
  font-size: 21rpx;
}

.result-card .result-tag {
  padding: 2rpx 7rpx;
  font-size: 16rpx;
}

.bottom-nav {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  background: #ffffff;
  border-radius: 18rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.14);
  padding: 10rpx;
  display: flex;
  gap: 10rpx;
}

.nav-item {
  flex: 1;
  text-align: center;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 25rpx;
  color: #334155;
  background: #f1f5f9;
}

.nav-item.active {
  background: #0f172a;
  color: #ffffff;
  font-weight: 600;
}
