<view class="container">
  <view class="hero">
    <view class="title">以图搜款</view>
    <view class="subtitle">上传图片或拍照，快速匹配相似款式</view>
  </view>

  <view class="mode-switch">
    <view class="mode-switch-inner">
      <view class="mode-item {{pageMode === 'image' ? 'active' : ''}}" bindtap="switchMode" data-mode="image">以图搜款</view>
      <view class="mode-item {{pageMode === 'catalog' ? 'active' : ''}}" bindtap="switchMode" data-mode="catalog">款库检索</view>
    </view>
  </view>

  <view wx:if="{{pageMode === 'catalog'}}" class="panel catalog-panel">
    <view class="section-title">款号 / 标签检索</view>
    <input
      class="catalog-input"
      placeholder="输入款号，如 GZ25-1177"
      value="{{catalogQuery}}"
      bindinput="onCatalogQueryInput"
      confirm-type="search"
      bindconfirm="searchCatalog"
    />
    <view class="tag-filter-list">
      <view
        wx:for="{{catalogTagItems}}"
        wx:key="name"
        class="tag-filter-item {{item.active ? 'active' : ''}}"
        bindtap="toggleCatalogTag"
        data-tag="{{item.name}}"
      >
        {{item.name}}
      </view>
    </view>
    <view class="catalog-actions">
      <button class="btn btn-main catalog-btn" bindtap="searchCatalog" loading="{{catalogLoading}}">查询款库</button>
      <button class="btn btn-sub catalog-btn" bindtap="clearCatalogFilters" disabled="{{!catalogQuery && !selectedCatalogTags.length}}">清空筛选</button>
    </view>
    <view wx:if="{{catalogLoading}}" class="loading-card">款库检索中...</view>
    <view wx:if="{{catalogErrorMessage}}" class="error-card">{{catalogErrorMessage}}</view>
    <view wx:if="{{!catalogLoading && !catalogErrorMessage && !catalogResults.length}}" class="empty-card">没有符合条件的产品</view>
    <view wx:if="{{catalogResults.length}}" class="catalog-result-wrap">
      <view class="card-list">
        <view wx:for="{{catalogResults}}" wx:key="styleCode" class="card" bindtap="previewCatalogProduct" data-index="{{index}}">
          <image class="card-image" src="{{item.coverImageUrl}}" mode="aspectFill" binderror="onCatalogImageError" data-index="{{index}}" />
          <view class="card-body">
            <view class="style-code">{{item.styleCode}}</view>
            <view class="catalog-meta">共 {{item.imageCount}} 张图 · 点击查看同款全部图片</view>
            <view class="result-tags">
              <text wx:for="{{item.tags}}" wx:key="*this" class="result-tag">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
      <view wx:if="{{catalogLoadingMore}}" class="loading-card">加载更多中...</view>
      <view wx:elif="{{!catalogHasMore}}" class="catalog-end">已加载全部产品</view>
    </view>
  </view>

  <view wx:if="{{pageMode === 'image'}}" class="panel">
    <view
      wx:if="{{localImage}}"
      class="query-wrap {{regionMode ? 'region-active' : ''}}"
      bindtouchstart="onRegionTouchStart"
      bindtouchmove="onRegionTouchMove"
      bindtouchend="onRegionTouchEnd"
      bindtouchcancel="onRegionTouchEnd"
    >
      <image class="query-image" src="{{localImage}}" mode="aspectFit" />
      <view wx:if="{{regionMode}}" class="region-mask"></view>
      <view
        wx:if="{{regionMode && cropRect}}"
        class="region-rect"
        style="left: {{cropRect.left}}px; top: {{cropRect.top}}px; width: {{cropRect.width}}px; height: {{cropRect.height}}px;"
      ></view>
    </view>
    <view wx:else class="placeholder">
      <view class="placeholder-icon">IMG</view>
      <view class="placeholder-text">请选择一张查询图片</view>
    </view>

    <view class="actions">
      <button class="btn btn-main" bindtap="chooseFromAlbum" loading="{{searching}}">从相册上传</button>
      <button class="btn btn-sub" bindtap="takePhoto" loading="{{searching}}">拍照上传</button>
    </view>
    <view wx:if="{{localImage}}" class="region-actions">
      <block wx:if="{{!regionMode}}">
        <button class="region-btn primary" bindtap="enableRegionSelect" disabled="{{searching}}">圈选区域</button>
      </block>
      <block wx:else>
        <button class="region-btn primary" bindtap="searchSelectedRegion" loading="{{searching}}">按区域搜索</button>
        <button class="region-btn" bindtap="clearRegionSelect" disabled="{{searching}}">清除圈选</button>
      </block>
    </view>
    <view wx:if="{{localImage && !hasSearched && !searching}}" class="search-tip">
      建议圈选目标款式或局部细节后搜索，优先匹配纹理、材质和结构。
    </view>
  </view>

  <view wx:if="{{searching}}" class="loading-card">检索中，请稍候...</view>
  <view wx:if="{{errorMessage}}" class="error-card">{{errorMessage}}</view>
  <view wx:if="{{errorMessage && localImage}}" class="retry-wrap">
    <button class="retry-btn" bindtap="retrySearch" loading="{{searching}}">手动重试</button>
  </view>

  <view wx:if="{{pageMode === 'image' && hasSearched && results.length}}" class="result-section">
    <view class="section-title">匹配结果</view>
    <view wx:if="{{isAmbiguous}}" class="ambiguous-tip">结果接近，已按相似候选展示，建议人工复核。</view>
    <view wx:elif="{{confidenceBand === 'medium'}}" class="medium-tip">匹配置信度中等，建议对比前几项。</view>
    <view class="result-grid">
      <view wx:for="{{results}}" wx:key="rank" class="card result-card" bindtap="previewResult" data-url="{{item.imageUrl}}" data-index="{{index}}">
        <image class="card-image result-image" src="{{item.imageUrl}}" mode="aspectFill" binderror="onResultImageError" data-index="{{index}}" />
        <view class="card-body result-body">
          <view class="card-top result-top">
            <text class="rank">#{{item.rank}}</text>
            <text class="score">{{item.scoreText}}</text>
          </view>
          <view class="style-code result-style-code">{{item.styleCode}}</view>
          <view class="result-tags result-grid-tags">
            <text wx:for="{{item.tags}}" wx:key="*this" class="result-tag">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item active" bindtap="goSearchPage">以图搜款</view>
    <view class="nav-item" bindtap="goRecolorPage">局部换色</view>
    <view class="nav-item" bindtap="goPrintPage">拼图打印</view>
  </view>
</view>
