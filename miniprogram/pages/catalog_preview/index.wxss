.preview-page { position: relative; min-height: 100vh; background: #000; color: #fff; overflow: hidden; }
.counter { position: absolute; top: 34rpx; left: 0; right: 0; z-index: 2; text-align: center; font-size: 30rpx; font-weight: 700; }
.swiper { width: 100vw; height: 100vh; }
.swiper-item { display: flex; align-items: center; justify-content: center; }
.preview-img { width: 100%; height: 100%; }
.bottom-bar { position: absolute; left: 0; right: 0; bottom: 0; z-index: 2; display: flex; align-items: center; gap: 18rpx; padding: 18rpx 24rpx calc(22rpx + env(safe-area-inset-bottom)); box-sizing: border-box; background: linear-gradient(180deg, rgba(0,0,0,0), rgba(0,0,0,.78)); }
.style-code { min-width: 0; flex: 1; font-size: 26rpx; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.origin-btn { flex: none; height: 68rpx; line-height: 68rpx; margin: 0; padding: 0 26rpx; border: 0; border-radius: 999rpx; background: #fff !important; color: #0f172a !important; font-size: 25rpx; font-weight: 800; }
.origin-btn::after { border: 0; }
