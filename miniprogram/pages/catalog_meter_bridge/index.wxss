.page {
  min-height: 100vh;
  background: #080b16;
  color: #fff;
  padding: 40rpx 28rpx;
  box-sizing: border-box;
}

.panel {
  width: 100%;
  display: grid;
  gap: 24rpx;
  box-sizing: border-box;
}

.spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  border: 6rpx solid rgba(95, 217, 233, 0.25);
  border-top-color: #5fd9e9;
  animation: spin 0.9s linear infinite;
}

.status {
  min-height: 72rpx;
  border-radius: 12rpx;
  background: #202435;
  padding: 18rpx 22rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.5;
  color: #eef6ff;
}

.device-list {
  display: grid;
  gap: 18rpx;
}

.device-row {
  min-height: 116rpx;
  border-radius: 12rpx;
  background: #202435;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 118rpx;
  gap: 14rpx;
  align-items: center;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
}

.device-row.preferred {
  outline: 2rpx solid #5fd9e9;
}

.device-main {
  min-width: 0;
}

.device-name {
  font-size: 30rpx;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.device-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8b91a3;
}

.connect-btn {
  width: 118rpx;
  height: 60rpx;
  border-radius: 999rpx;
  border: 2rpx solid #5fd9e9;
  background: transparent;
  color: #5fd9e9;
  font-size: 24rpx;
  line-height: 58rpx;
  text-align: center;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}

.connect-btn.disabled {
  opacity: 0.55;
}
.rescan-btn {
  width: 68%;
  min-height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #5fc7ea, #65ded7);
  color: #fff;
  font-size: 28rpx;
  padding: 0;
  margin: 14rpx auto 0;
}

.rescan-btn::after {
  border: 0;
}

.empty {
  color: #8b91a3;
  text-align: center;
  padding: 40rpx 0;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
